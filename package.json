{
  "name": "kitten-tts-js",
  "version": "0.1.2",
  "description": "Unofficial JavaScript/TypeScript port of KittenTTS (by KittenML/Stellon Labs) — ultra-lightweight TTS via ONNX models, runs in Node.js and browser",
  "type": "module",
  "exports": {
    ".": {
      "node": "./dist/index.node.js",
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "vite build",
    "build:slides-ollama": "vite build --config vite.config.slides-ollama.ts",
    "build:slides-web-llm": "vite build --config vite.config.slides-web-llm.ts",
    "build:slides-lab": "vite build --config vite.config.slides-lab.ts",
    "watch:slides-ollama": "vite build --config vite.config.slides-ollama.ts --watch",
    "watch:slides-web-llm": "vite build --config vite.config.slides-web-llm.ts --watch",
    "watch:slides-lab": "vite build --config vite.config.slides-lab.ts --watch",
    "build:pages": "vite build --config vite.config.pages.ts && npm run build:slides-lab && npm run build:slides-web-llm && npm run build:slides-ollama && cp node_modules/onnxruntime-web/dist/ort-wasm* docs/",
    "serve:docs": "serve docs -l tcp://0.0.0.0:3000",
    "dev": "npm run build:pages && npm run serve:docs",
    "watch:pages": "vite build --config vite.config.pages.ts --watch",
    "browser": "npm run build:pages && vite preview --config vite.config.pages.ts --port 4173 --strictPort --host 127.0.0.1",
    "benchmark:approaches": "node --experimental-strip-types scripts/benchmark-approaches.mjs --profile docs",
    "diagnose:node-runtime": "node --experimental-strip-types scripts/diagnose-node-runtime.mjs",
    "install:retry": "node scripts/install-with-npmmirror-fallback.mjs",
    "install:mirror": "npm install --registry=https://registry.npmmirror.com",
    "test": "tsx --test test/*.test.ts",
    "test:integration": "tsx --test test/*.itest.ts",
    "typecheck": "tsc --noEmit",
    "example": "npm run build && node examples/node-example.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@huggingface/hub": "^0.18.0",
    "jszip": "^3.10.1",
    "onnxruntime-node": "^1.20.0",
    "onnxruntime-web": "^1.20.0",
    "phonemizer": "^1.2.1",
    "wav-encoder": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.0",
    "playwright": "^1.58.2",
    "serve": "^14.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "onnx",
    "wasm",
    "kitten-tts",
    "voice",
    "synthesis",
    "styletts2"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Algiras/kitten-tts-js.git"
  },
  "homepage": "https://algiras.github.io/kitten-tts-js/",
  "bugs": {
    "url": "https://github.com/Algiras/kitten-tts-js/issues"
  }
}
